ENVIRONMENT=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/auth_db
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# JWT Keys - Auth service MUST have both private and public keys
# Since we auto-generate them in dev, this can be empty initially.
# In production, paste the base64-encoded PEM or literal string.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Social Auth
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=your_google_key
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=your_google_secret
SOCIAL_AUTH_FACEBOOK_KEY=your_fb_key
SOCIAL_AUTH_FACEBOOK_SECRET=your_fb_secret
