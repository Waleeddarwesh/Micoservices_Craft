msgid "You have already reviewed this course."
msgstr "لقد قمت بتقييم هذه الدورة بالفعل."

msgid "You have already reviewed this delivery."
msgstr "لقد قمت بتقييم هذا التوصيل بالفعل."

msgid "You have already reviewed this product."
msgstr "لقد قمت بتقييم هذا المنتج بالفعل."

msgid "You have already reviewed this supplier."
msgstr "لقد قمت بتقييم هذا المورد بالفعل."

msgid "You have received a new return request for '{product_name}'."
msgstr "لقد تلقيت طلب إرجاع جديد للمنتج '{product_name}'."

msgid "You have received a new review on '{review_target}' from {customer_name}."
msgstr "لقد تلقيت تقييمًا جديدًا على '{review_target}' من {customer_name}."

msgid "You have successfully cancelled your return request for '{product_name}'."
msgstr "لقد قمت بإلغاء طلب الإرجاع للمنتج '{product_name}' بنجاح."

msgid "You must be a customer to make a review."
msgstr "يجب أن تكون عميلاً لإضافة تقييم."

msgid "You must provide a business address before adding a product."
msgstr "يجب عليك إدخال عنوان العمل قبل إضافة منتج."

msgid "You must provide exactly one of product_id, course_id, delivery_id, or supplier_id."
msgstr "يجب عليك تقديم خيار واحد بالضبط من بين معرف المنتج، معرف الدورة، معرف التوصيل، أو معرف المورد."

msgid "Your course is being created and will be available shortly."
msgstr "جاري إنشاء دورتك وستكون متاحة قريباً."

msgid "Your delivery account has not been accepted yet.the adminstrators will accept your documents soon "
msgstr "لم يتم قبول حساب مندوب التوصيل الخاص بك بعد. سيراجع المسؤولون مستنداتك قريبًا."

msgid "Your order #%(order_num)s has been placed successfully!"
msgstr "تم تقديم طلبك رقم #%(order_num)s بنجاح!"

msgid "Your return request for '{product_name}' has been approved."
msgstr "تمت الموافقة على طلب الإرجاع الخاص بك للمنتج '{product_name}'."

msgid "Your return request for '{product_name}' has been rejected."
msgstr "تم رفض طلب الإرجاع الخاص بك للمنتج '{product_name}'."

msgid "Your return request for '{product_name}' has been submitted."
msgstr "تم تقديم طلب الإرجاع الخاص بك للمنتج '{product_name}'."

msgid "Your return request has been created successfully."
msgstr "تم إنشاء طلب الإرجاع الخاص بك بنجاح."

msgid "Your supplier account has not been accepted yet.the adminstrators will accept your documents soon "
msgstr "لم يتم قبول حساب المورّد الخاص بك بعد. سيراجع المسؤولون مستنداتك قريبًا."

msgid "Your verification passcode has been sent to your email."
msgstr "تم إرسال رمز التحقق الخاص بك إلى بريدك الإلكتروني."

msgid "Your withdrawal of EGP {amount:.2f} is complete and has been sent."
msgstr "اكتمل سحب مبلغ {amount:.2f} جنيه مصري وتم إرساله."

msgid "Your withdrawal request for EGP {amount:.2f} has been approved."
msgstr "تمت الموافقة على طلب السحب بقيمة {amount:.2f} جنيه مصري."

msgid "Your withdrawal request for EGP {amount:.2f} has been submitted for review."
msgstr "تم تقديم طلب السحب الخاص بك بقيمة {amount:.2f} جنيه مصري للمراجعة."

msgid "Your withdrawal request for EGP {amount:.2f} was rejected. Reason: {reason}"
msgstr "تم رفض طلب السحب الخاص بك بقيمة {amount:.2f} جنيه مصري. السبب: {reason}"

msgid "Your withdrawal request is being processed."
msgstr "جاري معالجة طلب السحب الخاص بك."

msgid "\nManually approved by {admin_name} on {date}."
msgstr "\nتمت الموافقة يدوياً بواسطة {admin_name} في {date}."

msgid "\nManually rejected by {admin_name} on {date}."
msgstr "\nتم الرفض يدوياً بواسطة {admin_name} في {date}."

msgid "message deleted"
msgstr "تم حذف الرسالة"

msgid "messages marked as read"
msgstr "تم وضع علامة مقروء على الرسائل"

msgid "upload your contract please ."
msgstr "يرجى تحميل العقد الخاص بك."

msgid "{user_name} started a conversation with you."
msgstr "بدأ {user_name} محادثة معك."
